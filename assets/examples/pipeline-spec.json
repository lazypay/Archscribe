{
  "layout": "pipeline",
  "style": "default",
  "animation": "flow",
  "title": {
    "prefix": "How a PR becomes",
    "highlight": "a Release",
    "subtitle": "CI/CD pipeline, from commit to production"
  },
  "subtitle": "Every push walks this path. Humans only step in when the gate says no.",
  "signature": "@archscribe",
  "stages": [
    {
      "title": "Commit",

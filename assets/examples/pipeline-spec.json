    },
    {
      "title": "Scan",
      "body": "lint, SAST and\nlicense checks",
      "icon": "shield",
      "note": "blocking on\nhigh severity"
    },
    {
      "title": "Stage",
      "body": "deploy to staging,\nsmoke tests",
      "icon": "server",
      "note": "ephemeral env\nper PR"
    }
  ],
